# =============================================================================
# Xiphos v2.6 -- Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# All variables are OPTIONAL unless marked [REQUIRED].
# Connectors degrade gracefully when keys are missing (reduced coverage,
# not failure).
#
# To load: export $(grep -v '^#' .env | xargs)
# Or use python-dotenv / direnv.
# =============================================================================


# ---------- Database Paths ----------
# SQLite databases. Defaults work for local development.

# Main application database (vendors, scoring results, alerts)
XIPHOS_DB_PATH=./xiphos.db

# OSINT enrichment cache database
XIPHOS_DB=./xiphos.db

# Knowledge graph database (entity relationships)
XIPHOS_KG_DB_PATH=./xiphos_kg.db

# Local sanctions database (OFAC/CSL sync target)
XIPHOS_SANCTIONS_DB=./sanctions.db


# ---------- API Keys: OSINT Connectors ----------
# These keys unlock additional data sources. Without them, the
# corresponding connector returns graceful "no data" instead of errors.

# SAM.gov (federal entity registration + exclusions)
# Get a free key at: https://api.sam.gov/
XIPHOS_SAM_API_KEY=

# OpenSanctions (PEP screening + World Bank debarment fallback)
# Free tier available at: https://www.opensanctions.org/api/
XIPHOS_OPENSANCTIONS_KEY=

# UK Companies House (beneficial ownership, PSC register)
# Free key at: https://developer.company-information.service.gov.uk/
XIPHOS_COMPANIES_HOUSE_KEY=

# OpenCorporates (global corporate registry, officers)
# Free tier at: https://api.opencorporates.com/
XIPHOS_OPENCORP_KEY=

# CourtListener (federal/state court dockets, litigation)
# Free token at: https://www.courtlistener.com/api/
XIPHOS_COURTLISTENER_TOKEN=


# ---------- No-Key Connectors ----------
# These connectors require NO API keys and work out of the box:
#
#   trade_csl          Trade.gov Consolidated Screening List (13 US lists)
#   un_sanctions       UN Security Council sanctions XML feed
#   icij_offshore      ICIJ Offshore Leaks (Panama/Paradise/Pandora Papers)
#   gdelt_media        GDELT adverse media monitoring
#   sec_edgar          SEC EDGAR filings and ownership
#   gleif_lei          GLEIF Legal Entity Identifiers
#   usaspending        Federal contract award history
#   epa_echo           EPA environmental violations
#   osha_safety        OSHA workplace safety records
#   fdic_bankfind      FDIC bank regulatory data
#   fara               DOJ FARA foreign agent registrations


# ---------- Authentication & RBAC ----------
# Set to "true" to enforce JWT auth + RBAC. Default: false (dev mode).
# In dev mode, all requests pass through as admin.
XIPHOS_AUTH_ENABLED=false

# [REQUIRED in production] Secret key for signing JWT tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
XIPHOS_SECRET_KEY=xiphos-dev-secret-change-in-production

# Bearer token expiry in hours (default: 8)
XIPHOS_TOKEN_EXPIRY_HOURS=8


# ---------- CORS ----------
# Comma-separated list of allowed origins. Leave empty to allow all (dev mode).
# Example: https://xiphos.yourdomain.com,https://admin.yourdomain.com
# XIPHOS_CORS_ORIGINS=


# ---------- Testing / Debug ----------

# Force OFAC screening to use fallback sanctions list (for offline testing)
# XIPHOS_SCREENING_FALLBACK=1
