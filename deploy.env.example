# Copy this file to deploy.env and fill in real values.
# Do not commit deploy.env.

# Preferred: use an SSH alias from ~/.ssh/config or an explicit user@host target.
XIPHOS_DEPLOY_SSH_TARGET=prod-xiphos

# Fallback if you are not using XIPHOS_DEPLOY_SSH_TARGET.
# XIPHOS_DEPLOY_HOST=203.0.113.10
# XIPHOS_DEPLOY_SSH_USER=root

# Optional key path override if your SSH config does not already specify one.
# XIPHOS_DEPLOY_SSH_KEY=~/.ssh/xiphos_do

# Remote app location.
XIPHOS_REMOTE_DIR=/opt/xiphos
XIPHOS_DOCKER_PORT=8080

# Public URL used for post-deploy verification.
XIPHOS_PUBLIC_BASE_URL=https://helios.example.com
XIPHOS_DEPLOY_DOMAIN=helios.example.com
XIPHOS_DEPLOY_VERIFY_TLS=true

# Optional auth-verified smoke credentials for deploy.py verification.
XIPHOS_DEPLOY_ADMIN_EMAIL=admin@yourorg.com
XIPHOS_DEPLOY_ADMIN_PASSWORD=replace-me

# Optional org-default AI provider bootstrap during deploy.sh.
# XIPHOS_AI_PROVIDER=openai
# XIPHOS_AI_MODEL=gpt-4o
# XIPHOS_AI_KEY=replace-me
